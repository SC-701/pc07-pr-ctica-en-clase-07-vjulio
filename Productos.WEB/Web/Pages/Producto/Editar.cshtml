@page
@model Web.Pages.Producto.EditarModel
@{
}

<h1>Agregar Producto</h1>
<div class="container">
	<div class="col-xl-5 col-lg-6 col-md-8 col-sm-10 mx-auto">
<form method="post">
	<div class="form-group">
		<label for="categorias">Categoría</label>
		<select asp-for="categoriaseleccionada" class="form-select" asp-items="Model.categorias" id="categorias" onchange="fectSubCategorias()">
			<option value ="">Seleccione una categoría</option>
		</select>
		</div>
	<div class="form-group">
		<label for="categorias">SubCategoría</label>
		<select asp-for="subcategoriaseleccionada" class="form-select" asp-items="Model.subcategorias" id="subcategorias">
			<option value="">Seleccione una sub-categoría</option>
		</select>
	</div>
	<div class="form-group">
				<label class="control-label" asp-for="producto.Nombre"></label>
		<input class="form-control" asp-for="producto.Nombre">
		<span class="text-danger" asp-validation-for="producto.Nombre"></span>
	</div>

	<div class="form-group">
					<label class="control-label" asp-for="producto.Descripcion"></label>
			<input class="form-control" asp-for="producto.Descripcion">
				<span class="text-danger" asp-validation-for="producto.Descripcion"></span>
	</div>
	<div class="form-group">
						<label class="control-label" asp-for="producto.Stock"></label>
						<input class="form-control" asp-for="producto.Stock">
							<span class="text-danger" asp-validation-for="producto.Stock"></span>
	</div>
	<div class="form-group">
						<label class="control-label" asp-for="producto.Precio"></label>
				<input class="form-control" asp-for="producto.Precio">
					<span class="text-danger" asp-validation-for="producto.Precio"></span>
	</div>
	<div class="form-group">
							<label class="control-label" asp-for="producto.CodigoBarras"></label>
					<input class="form-control" asp-for="producto.CodigoBarras">
						<span class="text-danger" asp-validation-for="producto.CodigoBarras"></span>
	</div>
	<div class="text-danger" asp-validation-summary="All"></div>
	<div class="form-group">
		<a class="btn btn-primary" asp-page="./index">Regresar</a>
		<input type="submit"  value="Agregar" class="btn btn-success"></>
	</div>
	</form>
	</div></div>
	@section Scripts{
		<script>
		async function fectSubCategorias(){
			
			const categoriaId = document.getElementById("categorias").value;
			if(!categoriaId){ return;}
			try{
				const respuesta = await fetch(`?handler=ObtenerSubCategoriasporCategoria&categoriaId=${categoriaId}`);
				const subcategorias = await respuesta.json();
				const subcategoriasSelect = document.getElementById("subcategorias");
				subcategoriasSelect.innerHTML = '<option value="">Seleccion una subcategoria</option>';
				subcategorias.forEach(
					subcategoria => {
						const option = document.createElement("option");
						option.value = subcategoria.id;
						option.text = subcategoria.nombre;
						subcategoriasSelect.appendChild(option);
					}
				)
			}catch(error){
				console.error('Error obteniendo las subcategorías',error);
			} 
		}
</script>
	
	
	}
